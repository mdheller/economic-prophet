{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://economic-prophet.dev/schemas/uvmc_tensor_mapping.schema.json",
  "title": "UVMC Tensor Mapping",
  "description": "Governed tensor or matrix mapping for KPI-to-EP, variance, risk-capital, knowledge-adjustment, and hypergraph diffusion mappings.",
  "type": "object",
  "required": [
    "tensor_mapping_id",
    "mapping_type",
    "axes",
    "entries",
    "model_version",
    "parameter_set",
    "status"
  ],
  "properties": {
    "tensor_mapping_id": {"type": "string", "minLength": 1},
    "mapping_type": {
      "type": "string",
      "enum": [
        "kpi_to_ep",
        "variance_bridge",
        "risk_capital",
        "knowledge_adjustment",
        "metric_space",
        "hypergraph_diffusion"
      ]
    },
    "description": {"type": "string"},
    "axes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["axis_name", "members"],
        "properties": {
          "axis_name": {"type": "string", "minLength": 1},
          "members": {"type": "array", "minItems": 1, "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["coordinates", "coefficient", "unit", "sign_convention"],
        "properties": {
          "coordinates": {"type": "object", "additionalProperties": {"type": "string"}},
          "coefficient": {"type": "number"},
          "unit": {"type": "string", "minLength": 1},
          "sign_convention": {"type": "string", "enum": ["positive_increases_ep", "positive_decreases_ep", "neutral", "custom"]},
          "calibration_method": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "evidence_refs": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "normalization_method": {"type": "string"},
    "model_version": {"type": "string", "minLength": 1},
    "parameter_set": {"type": "string", "minLength": 1},
    "formula_version": {"type": "string"},
    "owner": {"type": "string"},
    "status": {"type": "string", "enum": ["draft", "active", "inactive", "pending", "deprecated"]}
  },
  "additionalProperties": false
}
